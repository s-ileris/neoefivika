{
  "name": "neoefivika",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --no-server-fast-refresh",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "payload:upgrade": "pnpm add payload@latest @payloadcms/db-sqlite@latest @payloadcms/next@latest @payloadcms/richtext-lexical@latest @payloadcms/ui@latest @payloadcms/translations@latest",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^4.16.1",
    "@base-ui/react": "^1.4.0",
    "@headlessui/react": "^2.2.9",
    "@lexical/html": "^0.41.0",
    "@lexical/link": "^0.41.0",
    "@lexical/list": "0.41.0",
    "@lexical/mark": "0.41.0",
    "@lexical/react": "^0.41.0",
    "@payloadcms/db-sqlite": "3.82.1",
    "@payloadcms/next": "3.82.1",
    "@payloadcms/plugin-search": "^3.82.1",
    "@payloadcms/richtext-lexical": "3.82.1",
    "@payloadcms/storage-s3": "^3.82.1",
    "@payloadcms/ui": "3.82.1",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@upstash/search": "^0.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "firebase-admin": "^13.8.0",
    "graphql": "^16.8.1",
    "lexical": "^0.41.0",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "payload": "3.82.1",
    "postcss": "^8.5.8",
    "qs-esm": "^8.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "redis": "^5.11.0",
    "sanitize-html": "^2.17.2",
    "shadcn": "^4.2.0",
    "shaders": "^2.5.80",
    "sharp": "0.34.2",
    "slugify": "^1.6.9",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.1",
    "jsdom": "28.0.0",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
